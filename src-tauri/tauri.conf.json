{
  "productName": "Proxy Lab",
  "version": "1.0.0",
  "identifier": "jp.rua.proxylab",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Proxy Lab",
        "width": 700,
        "height": 560,
        "minWidth": 850,
        "minHeight": 420,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "backgroundColor": [
          26,
          26,
          27,
          255
        ]
        
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
	      ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}